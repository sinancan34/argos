{
  "enums": {
    "sortBy": ["name", "created_at", "updated_at"],
    "sortOrder": ["asc", "desc"]
  },

  "scenario": {
    "name":               { "type": "string",  "required": true,  "minLength": 1, "maxLength": 500 },
    "description":        { "type": "string",  "required": false },
    "status":             { "type": "boolean", "required": false, "default": true },
    "step_timeout":       { "type": "integer", "required": false, "default": 5000,  "positive": true },
    "validation_timeout": { "type": "integer", "required": false, "default": 10000, "positive": true },
    "steps":              { "type": "array",   "required": true,  "minItems": 1 },
    "validations":        { "type": "array",   "required": true,  "minItems": 1 },
    "device_id":          { "type": "string",  "required": true,  "minLength": 1 }
  },

  "device": {
    "name":   { "type": "string",  "required": true,  "minLength": 1, "maxLength": 500 },
    "status": { "type": "boolean", "required": false, "default": true },
    "meta":   { "type": "object",  "required": false }
  },

  "validation": {
    "provider": { "type": "enum", "required": true, "source": "providers", "default": "custom" }
  },

  "urlCheck": {
    "match": { "type": "enum",   "required": true, "source": "commands.matchTypes", "default": "contains" },
    "value": { "type": "string", "required": false, "conditionalRequired": {
      "unless": { "field": "match", "equals": "exists" },
      "minLength": 1
    }}
  },

  "paramCheck": {
    "key":   { "type": "string", "required": true, "minLength": 1 },
    "match": { "type": "enum",   "required": true, "source": "commands.matchTypes", "default": "exact" },
    "value": { "type": "string", "required": false, "conditionalRequired": {
      "unless": { "field": "match", "equals": "exists" },
      "minLength": 1
    }}
  }
}
